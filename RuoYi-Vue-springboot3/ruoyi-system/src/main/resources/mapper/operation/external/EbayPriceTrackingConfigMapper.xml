<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.operation.external.EbayPriceTrackingConfigMapper">

    <resultMap type="com.ruoyi.system.domain.operation.external.EbayPriceTrackingConfig" id="Result">
        <id property="id" column="id" />
        <result property="site" column="site" />
        <result property="sku" column="sku" />
        <result property="oeNumber" column="oe_number" />
        <result property="remark" column="remark" />
        <result property="trackingPrice" column="tracking_price" />
        <result property="trackingProfitMargin" column="tracking_profit_margin" />
        <result property="floorPrice" column="floor_price" />
        <result property="ourLowestPrice" column="our_lowest_price" />
        <result property="version" column="version" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <select id="selectAll" resultMap="Result">
        SELECT * FROM ebay_price_tracking_config
    </select>

    <select id="selectBySiteSku" resultMap="Result">
        SELECT * FROM ebay_price_tracking_config WHERE site = #{site} AND sku = #{sku}
    </select>

    <insert id="insert" parameterType="com.ruoyi.system.domain.operation.external.EbayPriceTrackingConfig" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ebay_price_tracking_config (site, sku, oe_number, remark, tracking_price, tracking_profit_margin, floor_price, our_lowest_price, version)
        VALUES (#{site}, #{sku}, #{oeNumber}, #{remark}, #{trackingPrice}, #{trackingProfitMargin}, #{floorPrice}, #{ourLowestPrice}, 0)
    </insert>

    <update id="updateWithVersion" parameterType="com.ruoyi.system.domain.operation.external.EbayPriceTrackingConfig">
        UPDATE ebay_price_tracking_config
        <set>
            <if test="oeNumber != null">oe_number = #{oeNumber},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="trackingPrice != null">tracking_price = #{trackingPrice},</if>
            <if test="trackingProfitMargin != null">tracking_profit_margin = #{trackingProfitMargin},</if>
            <if test="floorPrice != null">floor_price = #{floorPrice},</if>
            <if test="ourLowestPrice != null">our_lowest_price = #{ourLowestPrice},</if>
            version = version + 1
        </set>
        WHERE id = #{id} AND version = #{version}
    </update>

</mapper>
