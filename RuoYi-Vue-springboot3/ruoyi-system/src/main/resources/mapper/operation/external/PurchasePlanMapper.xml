    <select id="selectByStatusText" resultMap="Result">SELECT * FROM purchase_plan WHERE status_text=#{statusText}</select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO purchase_plan (plan_sn,ppg_sn,product_name,sku,fnsku,pic_url,supplier_id,supplier_name,status_text,status,sid,seller_name,marketplace,expect_arrive_time,remark,quantity_plan,product_id,cg_uid,cg_opt_username,cg_box_pcs,is_combo,is_aux,is_related_process_plan,spu,spu_name,creator_uid,creator_real_name,wid,warehouse_name,purchaser_id,purchaser_name,create_time,plan_remark,attribute_json,file_json,msku_json,perm_uid_json,perm_username_json)
