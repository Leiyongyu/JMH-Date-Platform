<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.operation.external.EbayReplenishFormulaMapper">

    <resultMap type="com.ruoyi.system.domain.operation.external.EbayReplenishFormula" id="Result">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="scenarioOrder" column="scenario_order"/>
        <result property="productNature" column="product_nature"/>
        <result property="conditionDesc" column="condition_desc"/>
        <result property="weight7d" column="weight_7d"/>
        <result property="weight15d" column="weight_15d"/>
        <result property="weight30d" column="weight_30d"/>
        <result property="multiplier" column="multiplier"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectAll" resultMap="Result">
        SELECT * FROM ebay_replenish_formula ORDER BY scenario_order
    </select>

    <select id="selectActive" resultMap="Result">
        SELECT * FROM ebay_replenish_formula WHERE status = 1 ORDER BY scenario_order
    </select>

    <select id="selectById" resultMap="Result">
        SELECT * FROM ebay_replenish_formula WHERE id = #{id}
    </select>

    <update id="update">
        UPDATE ebay_replenish_formula SET
            name = #{name}, weight_7d = #{weight7d}, weight_15d = #{weight15d},
            weight_30d = #{weight30d}, multiplier = #{multiplier}, status = #{status}
        WHERE id = #{id}
    </update>

</mapper>
