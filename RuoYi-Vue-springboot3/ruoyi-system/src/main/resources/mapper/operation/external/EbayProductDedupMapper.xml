<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.operation.external.EbayProductDedupMapper">

    <resultMap type="com.ruoyi.system.domain.operation.external.EbayProductDedup" id="Result">
        <id property="id" column="id" />
        <result property="site" column="site" />
        <result property="sku" column="sku" />
        <result property="productName" column="product_name" />
        <result property="profitRate" column="profit_rate" />
        <result property="returnRate" column="return_rate" />
        <result property="lowestPrice" column="lowest_price" />
        <result property="oeNumber" column="oe_number" />
        <result property="trackingPrice" column="tracking_price" />
        <result property="trackingProfitMargin" column="tracking_profit_margin" />
        <result property="floorPrice" column="floor_price" />
        <result property="remark" column="remark" />
    </resultMap>

    <select id="selectAll" resultMap="Result">
        SELECT id, site, sku, product_name, profit_rate, return_rate, lowest_price,
               oe_number, tracking_price, tracking_profit_margin, floor_price, remark
        FROM ebay_product_dedup
    </select>

</mapper>
