<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.operation.external.WarehouseInventoryDetailMapper">
    <resultMap type="com.ruoyi.system.domain.operation.external.WarehouseInventoryDetail" id="Result">
        <id property="id" column="id"/>
        <result property="wid" column="wid"/>
        <result property="sku" column="sku"/>
        <result property="productId" column="product_id"/>
        <result property="sellerId" column="seller_id"/>
        <result property="fnsku" column="fnsku"/>
        <result property="productValidNum" column="product_valid_num"/>
        <result property="productLockNum" column="product_lock_num"/>
        <result property="productOnway" column="product_onway"/>
        <result property="quantityReceive" column="quantity_receive"/>
    </resultMap>
    <select id="selectAll" resultMap="Result">SELECT * FROM warehouse_inventory_detail</select>
    <select id="selectByWids" resultMap="Result">
        SELECT * FROM warehouse_inventory_detail WHERE wid IN
        <foreach collection="list" item="w" open="(" separator="," close=")">#{w}</foreach>
    </select>
    <delete id="deleteAll">DELETE FROM warehouse_inventory_detail</delete>
    <insert id="batchInsert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO warehouse_inventory_detail (wid,sku,product_id,seller_id,fnsku,product_valid_num,product_lock_num,product_onway,quantity_receive) VALUES
        <foreach collection="list" item="e" separator=",">
        (#{e.wid},#{e.sku},#{e.productId},#{e.sellerId},#{e.fnsku},#{e.productValidNum},#{e.productLockNum},#{e.productOnway},#{e.quantityReceive})
        </foreach>
    </insert>
</mapper>
