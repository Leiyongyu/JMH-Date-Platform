<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.operation.external.AmzOrderProfitMapper">
    <resultMap type="com.ruoyi.system.domain.operation.external.AmzOrderProfit" id="Result">
        <id property="id" column="id"/>
        <result property="sid" column="sid"/>
        <result property="sellerSku" column="seller_sku"/>
        <result property="grossMargin" column="gross_margin"/>
        <result property="spendRate" column="spend_rate"/>
        <result property="refundAmountRate" column="refund_amount_rate"/>
    </resultMap>

    <select id="selectBySidSku" resultMap="Result">
        SELECT * FROM amz_order_profit WHERE sid=#{sid} AND seller_sku=#{sellerSku}
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO amz_order_profit (sid,seller_sku,gross_margin,spend_rate,refund_amount_rate)
        VALUES (#{sid},#{sellerSku},#{grossMargin},#{spendRate},#{refundAmountRate})
    </insert>
    <update id="updateById">
        UPDATE amz_order_profit SET gross_margin=#{grossMargin},spend_rate=#{spendRate},refund_amount_rate=#{refundAmountRate}
        WHERE id=#{id}
    </update>
    <insert id="batchInsert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO amz_order_profit (sid,seller_sku,gross_margin,spend_rate,refund_amount_rate) VALUES
        <foreach collection="list" item="e" separator=",">
        (#{e.sid},#{e.sellerSku},#{e.grossMargin},#{e.spendRate},#{e.refundAmountRate})
        </foreach>
    </insert>
    <delete id="deleteAll">DELETE FROM amz_order_profit</delete>
</mapper>
