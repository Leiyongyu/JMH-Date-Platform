<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.operation.external.GoodcangWarehouseMapper">
    <resultMap type="com.ruoyi.system.domain.operation.external.GoodcangWarehouse" id="Result">
        <id property="id" column="id"/>
        <result property="warehouseCode" column="warehouse_code"/>
        <result property="warehouseName" column="warehouse_name"/>
        <result property="countryCode" column="country_code"/>
        <result property="wpCode" column="wp_code"/>
        <result property="wpName" column="wp_name"/>
        <result property="wid" column="wid"/>
    </resultMap>
    <select id="selectAll" resultMap="Result">SELECT * FROM goodcang_warehouse</select>
    <select id="selectByWarehouseCodes" resultMap="Result">
        SELECT * FROM goodcang_warehouse WHERE warehouse_code IN
        <foreach collection="list" item="code" open="(" separator="," close=")">#{code}</foreach>
    </select>
    <delete id="deleteAll">DELETE FROM goodcang_warehouse</delete>
    <insert id="batchInsert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO goodcang_warehouse (warehouse_code,warehouse_name,country_code,wp_code,wp_name,wid) VALUES
        <foreach collection="list" item="e" separator=",">
        (#{e.warehouseCode},#{e.warehouseName},#{e.countryCode},#{e.wpCode},#{e.wpName},#{e.wid})
        </foreach>
    </insert>
</mapper>
