<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.operation.external.PurchaseOrderMapper">

    <resultMap type="com.ruoyi.system.domain.operation.external.PurchaseOrder" id="Result">
        <id property="id" column="id" />
        <result property="orderSn" column="order_sn" />
        <result property="statusText" column="status_text" />
        <result property="wid" column="wid" />
        <result property="wareHouseName" column="ware_house_name" />
        <result property="itemSku" column="item_sku" />
        <result property="orderTime" column="order_time" />
    </resultMap>

    <select id="selectAll" resultMap="Result">
        SELECT id, order_sn, status_text, wid, ware_house_name, item_sku, order_time
        FROM purchase_order
    </select>

</mapper>
