<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.operation.external.BrandOwnerMapper">

    <resultMap type="com.ruoyi.system.domain.operation.external.BrandOwner" id="Result">
        <id property="id" column="id" />
        <result property="brandCode" column="brand_code" />
        <result property="ownerName" column="owner_name" />
        <result property="userId" column="user_id" />
    </resultMap>

    <select id="selectAll" resultMap="Result">
        SELECT id, brand_code, owner_name, user_id FROM brand_owner
    </select>

    <insert id="insert" parameterType="com.ruoyi.system.domain.operation.external.BrandOwner" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO brand_owner (brand_code, owner_name, user_id) VALUES (#{brandCode}, #{ownerName}, #{userId})
    </insert>

    <update id="update" parameterType="com.ruoyi.system.domain.operation.external.BrandOwner">
        UPDATE brand_owner SET brand_code = #{brandCode}, owner_name = #{ownerName}, user_id = #{userId} WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM brand_owner WHERE id = #{id}
    </delete>

</mapper>
